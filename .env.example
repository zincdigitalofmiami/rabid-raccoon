# ── Database ──────────────────────────────────────────────────────────
# DIRECT_URL is the canonical DB connection for everything:
#   - Next.js app (via Prisma + @prisma/adapter-pg)
#   - Inngest functions (compute-signal and all ingestion)
#   - All TypeScript scripts (backfill, ingest, build-dataset)
#   - All Python scripts (psycopg2 direct connection)
#   - Prisma CLI (migrate, studio) — via prisma.config.ts
#
# Set this to your cloud Postgres direct connection string:
DIRECT_URL=postgres://TENANT:SECRET@db.neon.tech:5432/neondb?sslmode=require
#
# DATABASE_URL is only needed if you explicitly opt in to Prisma Accelerate
# for edge caching. Set USE_ACCELERATE=1 to activate.
# DATABASE_URL=prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_KEY
# USE_ACCELERATE=1

# Market data providers
DATABENTO_API_KEY=your_databento_key
FRED_API_KEY=your_fred_key

# ── AI Provider (Claude Code Max subscription — $0.00) ───────────────
# ALL AI in this app routes through CLIProxyAPI, which proxies to your
# Claude Code Max subscription. No per-token billing. No API key needed.
#
# ── How to start the proxy ────────────────────────────────────────────
#
#   npx @anthropic-ai/claude-code --serve --port 8317
#   # or: npx cliproxyapi --port 8317
#
# Then set the URL below. The proxy must be reachable from:
#   - next dev   (local)
#   - Inngest Dev Server  (npx inngest-cli@latest dev)
#   - Vercel production  (expose via ngrok/Cloudflare tunnel if needed,
#                         or deploy the proxy alongside the app)
#
CLAUDE_PROXY_URL=http://localhost:8317/v1
#
# Model to use (default: claude-sonnet-4-5):
# CLAUDE_MODEL=claude-sonnet-4-5

# Inngest (scheduled ingestion + 15-minute compute-signal pipeline)
INNGEST_EVENT_KEY=your_inngest_event_key
INNGEST_SIGNING_KEY=your_inngest_signing_key
