# Database — direct-only contract
#
# 1. Direct Postgres fallback
DATABASE_URL=postgres://TENANT:SECRET@db.prisma.io:5432/postgres?sslmode=require
# 2. Direct Postgres (preferred runtime + scripts + Prisma CLI target when direct)
DIRECT_URL=postgres://TENANT:SECRET@db.prisma.io:5432/postgres?sslmode=require
# 3. Local Postgres (used when PRISMA_LOCAL=1 / PRISMA_TARGET=local / LOCAL_DEV=1)
LOCAL_DATABASE_URL=postgresql://YOUR_USER@localhost:5432/rabid_raccoon
#
# Optional runtime/CLI routing controls:
# PRISMA_LOCAL=1          # pick LOCAL_DATABASE_URL for Prisma CLI/runtime target resolution
# PRISMA_TARGET=local     # explicit override: local | direct
# LOCAL_DEV=1             # local convenience flag for resolver
#
# Routing summary:
#   runtime (default)   → DIRECT_URL, fallback LOCAL_DATABASE_URL, then direct DATABASE_URL
#   prisma CLI          → DIRECT_URL by default, LOCAL_DATABASE_URL when local target selected
#   fail-closed rule    → accelerate URLs are treated as invalid/unavailable

# Market data providers
DATABENTO_API_KEY=your_databento_key
FRED_API_KEY=your_fred_key

# ── AI Provider (OpenRouter via Vercel AI SDK) ──────────────────────
# Single provider for ALL AI in the app: analysis, forecast, reasoning,
# chart vision, synthesis.
OPENROUTER_API_KEY=sk-or-v1-...
#
# Optional: override the OpenRouter-compatible base URL.
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
#
# Optional: override text/chat and vision model IDs.
# OPENROUTER_TEXT_MODEL=arcee-ai/trinity-large-preview:free
# OPENROUTER_VISION_MODEL=qwen/qwen3-vl-235b-a22b-thinking
#
# Optional: compatibility knob retained by the provider layer.
# OPENROUTER_THINKING_BUDGET=10000
#
# Optional OpenRouter attribution headers.
# OPENROUTER_HTTP_REFERER=https://your-app.example
# OPENROUTER_X_TITLE=Rabid Raccoon

# Inngest (daily ingestion scheduler)
INNGEST_EVENT_KEY=your_inngest_event_key
INNGEST_SIGNING_KEY=your_inngest_signing_key
