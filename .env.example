# Database — three-URL pattern
#
# 1. Vercel production — Accelerate proxy (pooled, serverless connection management)
DATABASE_URL=prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_ACCELERATE_KEY
# 2. Direct connection — Prisma CLI (migrate, studio) + ALL batch/ingestion scripts
#    Bypasses Accelerate entirely: no per-op cost, no 5s timeout, unlimited batch size.
DIRECT_URL=postgres://TENANT:SECRET@db.prisma.io:5432/postgres?sslmode=require
# 3. Local dev — next dev uses this so zero Accelerate operations are burned locally.
#    Must be kept in sync with Production via migrations (prisma migrate deploy).
LOCAL_DATABASE_URL=postgresql://YOUR_USER@localhost:5432/rabid_raccoon
#
# Routing summary:
#   next dev            → LOCAL_DATABASE_URL (local Postgres, free)
#   batch scripts (.py) → DIRECT_URL (direct to Production, no Accelerate cost)
#   Vercel production   → DATABASE_URL (Accelerate, connection pooling for serverless)
#   prisma migrate      → DIRECT_URL (via prisma.config.ts)

# Market data providers
DATABENTO_API_KEY=your_databento_key
FRED_API_KEY=your_fred_key

# ── AI Provider (Claude via Vercel AI SDK) ──────────────────────────
# Single provider for ALL AI in the app: analysis, forecast, reasoning,
# chart vision, synthesis, and the 15-minute compute-signal pipeline.
# Uses ai-provider.ts — one file, one config, three auth paths.
#
# Priority: CLAUDE_PROXY_URL (proxy) > Vercel AI Gateway (OIDC) > API Key
#
# ── Path 1: Vercel AI Gateway + OIDC (Vercel production/preview, $0.00) ──
# `vercel env pull .env.local` writes VERCEL_OIDC_TOKEN automatically.
# No manual config needed when deployed on Vercel with Max subscription.
# Set this in Vercel dashboard: AI > Gateway > Enable for project.
ANTHROPIC_BASE_URL=https://ai-gateway.vercel.sh/v1
#
# ── Path 2: CLIProxyAPI local proxy (local dev, $0.00 with Max sub) ──────
# Start proxy: npx cliproxyapi --port 8317
# Then set:
# CLAUDE_PROXY_URL=http://localhost:8317/v1
# This routes all Claude calls through your local Max subscription.
# No API key required. Works for next dev and npx inngest-cli@latest dev.
#
# ── Path 3: Direct Anthropic API key (per-token billing) ─────────────────
# ANTHROPIC_API_KEY=sk-ant-...
#
# Model override (default: anthropic/claude-sonnet-4-5):
# CLAUDE_MODEL=anthropic/claude-sonnet-4-5
#
# Extended thinking token budget (default: 10000 tokens):
# CLAUDE_THINKING_BUDGET=10000
# Set to 0 to disable extended thinking (faster, lower cost).
# compute-signal uses 4000, ai-synthesis uses 2000, trade-reasoning uses 4000.

# Inngest (scheduled ingestion + 15-minute compute-signal pipeline)
INNGEST_EVENT_KEY=your_inngest_event_key
INNGEST_SIGNING_KEY=your_inngest_signing_key
